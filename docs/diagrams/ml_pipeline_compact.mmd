flowchart LR
    subgraph TRIGGER["Trigger (60s)"]
        direction TB
        DAEMON["live_forecast_watcher.py<br/>Running as daemon"] --> CHECK["sensor_has_recent_data()?"] --> CONDITION{"Data tersedia?"}
    end

    subgraph FETCH["Data Fetching"]
        direction TB
        FETCH_DATA["fetch_recent_data()<br/>4320 menit sensor"] --> PARAMS["pm25, pm10, co,<br/>temperature, humidity"]
    end

    subgraph FEATURES["Feature Engineering"]
        direction TB
        LAG["Lag: 1, 5, 15, 60m"] --> ROLLING["Rolling: mean, std"] --> TIME["Time: hour, dayofweek,<br/>day_sin / day_cos"]
    end

    subgraph MODEL["XGBoost v2 Forecasting"]
        direction TB
        XGB_PM25["xgb_pm25_v2.pkl"] --> RECURSIVE["60-step recursive<br/>multi-stage forecast"]
        XGB_PM10["xgb_pm10_v2.pkl"] --> RECURSIVE
        XGB_CO["xgb_co_v2.pkl"] --> RECURSIVE
    end

    subgraph FALLBACK["Fallback"]
        direction TB
        HOLTWINTERS["Holt-Winters<br/>Exponential Smoothing"]
    end

    subgraph CLASSIFY["ISPU Classification"]
        direction TB
        CI["Confidence Interval<br/>Upper/Lower 95%"] --> RF_MODEL["Random Forest<br/>Classifier"] --> CATEGORIES["5 Kategori ISPU"] --> CONFIDENCE["Confidence Score"]
    end

    subgraph SAVE["Save Results"]
        direction TB
        SAVE_HOURLY["save_hourly_predictions()"] --> SUPABASE["tb_prediksi_hourly"]
        SAVE_FITTED["save_fitted_values()"] --> SUPABASE2["tb_fitted_values"]
    end

    subgraph DISPLAY["Frontend Display"]
        direction TB
        REALTIME["Supabase Realtime"] --> FORECAST_PAGE["/statistik<br/>Forecast Charts"]
    end

    CONDITION -->|"Ya"| FETCH_DATA
    CONDITION -->|"Tidak"| DAEMON

    PARAMS --> LAG
    TIME --> RECURSIVE
    TIME --> HOLTWINTERS

    HOLTWINTERS --> CI
    RECURSIVE --> CI

    CI --> RF_MODEL
    CONFIDENCE --> SAVE_HOURLY
    CONFIDENCE --> SAVE_FITTED

    SUPABASE --> REALTIME
    SUPABASE2 --> REALTIME

    classDef trigger fill:#2c3e50,color:#fff
    classDef fetch fill:#3498db,color:#fff
    classDef feature fill:#9b59b6,color:#fff
    classDef model fill:#e67e22,color:#fff
    classDef fallback fill:#e74c3c,color:#fff
    classDef classify fill:#2ecc71,color:#fff
    classDef save fill:#1abc9c,color:#fff
    classDef display fill:#f39c12,color:#fff
    classDef db fill:#34495e,color:#fff

    class DAEMON,CHECK,CONDITION trigger
    class FETCH_DATA,PARAMS fetch
    class LAG,ROLLING,TIME feature
    class XGB_PM25,XGB_PM10,XGB_CO,RECURSIVE,CI model
    class HOLTWINTERS fallback
    class RF_MODEL,CATEGORIES,CONFIDENCE classify
    class SAVE_HOURLY,SAVE_FITTED save
    class FORECAST_PAGE,REALTIME display
    class SUPABASE,SUPABASE2 db
